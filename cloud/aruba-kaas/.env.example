# Aruba KaaS API authentication
KAAS_API_KEY=replace-with-your-aruba-api-key

# Aruba API base URL (override if your account uses a different endpoint)
KAAS_API_BASE_URL=https://api.cloud.it

# Aruba identifiers
KAAS_PROJECT_ID=replace-with-project-id
KAAS_CLUSTER_ID=replace-with-cluster-id
KAAS_REGION=it-milan-1

# Elastic IP defaults
KAAS_EIP_NAME=nuvolaris-eip

# Kubernetes service to expose externally
KAAS_SERVICE_NAMESPACE=ingress-nginx
KAAS_SERVICE_NAME=ingress-nginx-controller

# Optional endpoint overrides (leave empty to use default URLs built from values above)
# KAAS_EIP_CREATE_URL=
# KAAS_EIP_ATTACH_URL=

API_HOST=85.235.141.133.nip.io

